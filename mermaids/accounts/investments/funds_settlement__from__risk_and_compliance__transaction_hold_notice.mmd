flowchart LR
  subgraph IN["risk_and_compliance: transaction_hold_notice"]
    in_noticeId["noticeId"]
    in_holdEffectiveDate["holdEffectiveDate"]
    in_department["department"]
    in_recipientDepartment["recipientDepartment"]
    in_transactionsAffected___amount["transactionsAffected[].amount"]
    in_transactionsAffected["transactionsAffected"]
  end
  subgraph OUT["accounts: funds_settlement"]
    out_settlement_id["settlement_id"]
    out_settlement_date["settlement_date"]
    out_from_department["from_department"]
    out_to_department["to_department"]
    out_currency["currency"]
    out_total_amount["total_amount"]
    out_settlement_status["settlement_status"]
    out_settlements["settlements"]
  end
  in_noticeId -->|EXACT| out_settlement_id
  in_holdEffectiveDate -->|SEMANTIC| out_settlement_date
  in_department -->|RENAMED| out_from_department
  in_recipientDepartment -->|EXACT| out_to_department
  in_transactionsAffected___amount -->|MERGE| out_total_amount
  in_transactionsAffected -->|SEMANTIC| out_settlements
flowchart LR
  subgraph IN["credit: monthly_repayment_direct_debit"]
    in_repaymentId["repaymentId"]
    in_timestamp["timestamp"]
    in_department_from["department.from"]
    in_department_to["department.to"]
    in_repayments___accountNumber["repayments[].accountNumber"]
    in_repayments___currency["repayments[].currency"]
    in_totalAmount["totalAmount"]
    in_repayments["repayments"]
  end
  subgraph OUT["accounts: available_cash_balance"]
    out_messageId["messageId"]
    out_timestamp["timestamp"]
    out_fromDepartment["fromDepartment"]
    out_toDepartment["toDepartment"]
    out_subject["subject"]
    out_accountNumber["accountNumber"]
    out_currency["currency"]
    out_availableCashBalance["availableCashBalance"]
    out_asOfDate["asOfDate"]
    out_details["details"]
    out_notes["notes"]
  end
  in_repaymentId -->|RENAMED| out_messageId
  in_timestamp -->|EXACT| out_timestamp
  in_department_from -->|RENAMED| out_fromDepartment
  in_department_to -->|RENAMED| out_toDepartment
  in_repayments___accountNumber -->|SEMANTIC| out_accountNumber
  in_repayments___currency -->|SEMANTIC| out_currency
  in_totalAmount -->|TRANSFORMED| out_availableCashBalance
  in_repayments -->|SEMANTIC| out_details
  end
  in_customer_id -->|EXACT| out_customer_customer_id
  in_customer_name -->|RENAMED| out_customer_name
  in_credit_score -->|SEMANTIC| out_credit_score_score
  in_total_credit_limit -->|EXACT| out_credit_assessment_total_credit_limit
  in_outstanding_balance -->|EXACT| out_credit_assessment_outstanding_balance
  in_utilization_rate -->|SEMANTIC| out_credit_assessment_utilization_rate
  in_fraud_risk -->|SEMANTIC| out_risk_indicators_fraud_risk
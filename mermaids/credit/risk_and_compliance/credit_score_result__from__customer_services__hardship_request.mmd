flowchart LR
  subgraph IN["customer_services: hardship_request"]
    in_customer_id["customer_id"]
    in_customer_name["customer_name"]
    in_credit_score["credit_score"]
    in_total_credit_limit["total_credit_limit"]
    in_outstanding_balance["outstanding_balance"]
